# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# LLM API settings (OpenAI-compatible endpoint)
API_KEY=not-needed
API_BASE=http://uaai-vl-sglang.onyx.svc:8000/v1
MODEL_NAME=qwen3.5-35b-a3b
TEMPERATURE=0.3

# Context engineering limits
MAX_SEARCH_RESULTS=5
MAX_SEARCH_CONTENT_LENGTH=4000
MAX_URL_CONTENT_LENGTH=8000

# Agent iteration limits
MAX_ITERATIONS=15
MAX_TOOL_CALLS=5

# Output directory for reports
OUTPUT_DIR=output
