# Copy to .env and adjust values
#   cp .env.example .env

# LLM API (OpenAI-compatible, e.g. vLLM / SGLang)
API_KEY=not-needed
API_BASE=http://localhost:8000/v1
MODEL_NAME=qwen3.5-35b-a3b
TEMPERATURE=0.3

# Embedding service (OpenAI-compatible, e.g. TEI)
EMBEDDING_API_KEY=not-needed
EMBEDDING_BASE_URL=http://localhost:7998/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Reranker (Infinity API)
RERANKER_URL=http://localhost:7997/rerank

# Context engineering limits
MAX_SEARCH_RESULTS=5
MAX_SEARCH_CONTENT_LENGTH=4000
MAX_URL_CONTENT_LENGTH=8000
MAX_KNOWLEDGE_CONTENT_LENGTH=6000

# Agent
MAX_ITERATIONS=50
MAX_REVISION_ROUNDS=2

# RAG (reused hw8 index by default — point these at hw8 to skip re-ingest)
DATA_DIR=../homework-lesson-8/data
INDEX_DIR=../homework-lesson-8/index
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=10
RERANK_TOP_N=3
FILTERED_RERANK_TOP_N=10

# Output directory for reports
OUTPUT_DIR=output

# MCP / ACP endpoints
SEARCH_MCP_HOST=127.0.0.1
SEARCH_MCP_PORT=8901
REPORT_MCP_HOST=127.0.0.1
REPORT_MCP_PORT=8902
ACP_HOST=127.0.0.1
ACP_PORT=8903
