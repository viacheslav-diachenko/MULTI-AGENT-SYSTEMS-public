# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# LLM API settings (OpenAI-compatible endpoint)
API_KEY=not-needed
API_BASE=http://localhost:8000/v1
MODEL_NAME=qwen3.5-35b-a3b

# Embedding service (OpenAI-compatible endpoint, e.g. TEI or OpenAI)
# For OpenAI: set EMBEDDING_API_KEY=sk-your-key, EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=not-needed
EMBEDDING_BASE_URL=http://localhost:7998/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Reranker service (Infinity API)
RERANKER_URL=http://localhost:7997/rerank

# Context engineering limits
MAX_SEARCH_RESULTS=5
MAX_SEARCH_CONTENT_LENGTH=4000
MAX_URL_CONTENT_LENGTH=8000
MAX_KNOWLEDGE_CONTENT_LENGTH=6000

# Agent
MAX_ITERATIONS=30

# RAG settings
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=10
RERANK_TOP_N=3
FILTERED_RERANK_TOP_N=10

# Output directory for reports
OUTPUT_DIR=output
